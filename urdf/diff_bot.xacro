<?xml version="1.0"?>
<robot name="diff_drive_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="PI" value="3.1415926535897931"/>
  <xacro:property name="chassis_length" value="0.5"/>
  <xacro:property name="chassis_width" value="0.3"/>
  <xacro:property name="chassis_height" value="0.15"/>
  <xacro:property name="wheel_radius" value="0.08"/>
  <xacro:property name="wheel_width" value="0.04"/>
  <xacro:property name="wheel_separation" value="0.35"/>
  <xacro:property name="caster_radius" value="0.04"/>

  <link name="base_link"/>
  <link name="base_footprint"/>

  <!--
    FIX 1: Removed the extra +0.01 offset.
    Previously: wheel_radius + 0.01 = 0.09 → wheels were 1 cm above ground → robot bounced/slid.
    Now: exactly wheel_radius so wheel bottoms sit flush on the ground plane.
  -->
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- Chassis -->
  <link name="chassis">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <material name="orange">
        <color rgba="1.0 0.5 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="5.0"/>
      <!-- Box inertia: m=5, l=0.5, w=0.3, h=0.15
           ixx = m(w²+h²)/12 = 5*(0.09+0.0225)/12 = 0.04688
           iyy = m(l²+h²)/12 = 5*(0.25+0.0225)/12 = 0.11354
           izz = m(l²+w²)/12 = 5*(0.25+0.09)/12   = 0.14167 -->
      <inertia
        ixx="0.04688" ixy="0.0" ixz="0.0"
        iyy="0.11354" iyz="0.0"
        izz="0.14167"/>
    </inertial>
  </link>

  <joint name="chassis_joint" type="fixed">
    <parent link="base_link"/>
    <child link="chassis"/>
    <origin xyz="0 0 ${chassis_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- Left Wheel -->
  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <inertial>
      <!--
        FIX 2: Inertial frame rotated to match visual/collision rpy="${PI/2} 0 0".
        The cylinder spins around the Y-axis (after the PI/2 rotation), so
        the spin-axis inertia (izz in the unrotated frame = mr²/2) must map to iyy.
        With rpy="${PI/2} 0 0":
          ixx_new = izz_old = mr²/2        = 0.5*0.0064/2        = 0.0016
          iyy_new = iyy_old = m(3r²+h²)/12 = 0.5*(0.0192+0.0016)/12 = 0.000867
          izz_new = ixx_old = m(3r²+h²)/12 = 0.000867
      -->
      <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      <mass value="0.5"/>
      <inertia
        ixx="0.0016"    ixy="0.0" ixz="0.0"
        iyy="0.000867"  iyz="0.0"
        izz="0.000867"/>
    </inertial>
  </link>

  <!--
    FIX 3: Added <dynamics> to wheel joints.
    Without damping/friction the wheels oscillate freely, adding noise to odometry.
  -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 ${wheel_separation/2} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.01"/>
  </joint>

  <!-- Right Wheel -->
  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <inertial>
      <!-- Same fix as left wheel -->
      <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      <mass value="0.5"/>
      <inertia
        ixx="0.0016"    ixy="0.0" ixz="0.0"
        iyy="0.000867"  iyz="0.0"
        izz="0.000867"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 ${-wheel_separation/2} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.01"/>
  </joint>

  <!-- Front Caster Wheel -->
  <link name="caster_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="${caster_radius}"/></geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="${caster_radius}"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <!-- Sphere inertia: 2mr²/5 = 2*0.1*0.0016/5 = 0.000064 -->
      <inertia
        ixx="0.000064" ixy="0.0" ixz="0.0"
        iyy="0.000064" iyz="0.0"
        izz="0.000064"/>
    </inertial>
  </link>

  <!--
    FIX 4: Caster Z offset corrected to match the new base_link height.
    base_link is at wheel_radius above ground.
    Caster center must be at (wheel_radius - caster_radius) below base_link
    so its bottom sits flush on the ground: 0.08 - 0.04 = 0.04 below base_link.
    Formula: -wheel_radius + caster_radius = -0.08 + 0.04 = -0.04 ✓
    (This was already the right formula; the bug was in base_footprint_joint offset.)
  -->
  <joint name="caster_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="${chassis_length/3} 0 ${-wheel_radius + caster_radius}" rpy="0 0 0"/>
  </joint>

  <!-- Rear Caster Wheel -->
  <link name="rear_caster_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="${caster_radius}"/></geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="${caster_radius}"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia
        ixx="0.000064" ixy="0.0" ixz="0.0"
        iyy="0.000064" iyz="0.0"
        izz="0.000064"/>
    </inertial>
  </link>

  <joint name="rear_caster_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_caster_wheel"/>
    <origin xyz="${-chassis_length/3} 0 ${-wheel_radius + caster_radius}" rpy="0 0 0"/>
  </joint>

  <!-- LiDAR -->
  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.05" length="0.06"/></geometry>
      <material name="red"><color rgba="1.0 0.0 0.0 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.05" length="0.06"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia
        ixx="0.000117" ixy="0.0" ixz="0.0"
        iyy="0.000117" iyz="0.0"
        izz="0.00025"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="chassis"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 ${chassis_height/2 + 0.06/2 + 0.01}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== Gazebo Plugins ==================== -->

  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>${wheel_separation}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <max_linear_acceleration>1.0</max_linear_acceleration>
      <max_angular_acceleration>2.0</max_angular_acceleration>
      <max_linear_velocity>0.5</max_linear_velocity>
      <max_angular_velocity>1.0</max_angular_velocity>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
    </plugin>
  </gazebo>

  <!-- LiDAR Plugin -->
  <gazebo reference="lidar_link">
    <sensor name="lidar" type="gpu_lidar">
      <pose>0 0 0 0 0 0</pose>
      <topic>scan</topic>
      <update_rate>10</update_rate>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-${PI}</min_angle>
            <max_angle>${PI}</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.1</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
      <alwaysOn>1</alwaysOn>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-pose-publisher-system"
            name="gz::sim::systems::PosePublisher">
      <publish_link_pose>true</publish_link_pose>
      <use_pose_vector_msg>true</use_pose_vector_msg>
      <static_publisher>true</static_publisher>
      <static_update_frequency>1</static_update_frequency>
    </plugin>
  </gazebo>

  <!-- Drive wheels: high friction, firm contact -->
  <gazebo reference="left_wheel">
    <material>Gazebo/Black</material>
    <surface>
      <friction>
        <ode>
          <mu>1.5</mu>
          <mu2>1.5</mu2>
          <slip1>0.0</slip1>
          <slip2>0.0</slip2>
        </ode>
      </friction>
      <contact>
        <ode>
          <kp>1000000.0</kp>
          <kd>1.0</kd>
          <min_depth>0.001</min_depth>
        </ode>
      </contact>
    </surface>
  </gazebo>

  <gazebo reference="right_wheel">
    <material>Gazebo/Black</material>
    <surface>
      <friction>
        <ode>
          <mu>1.5</mu>
          <mu2>1.5</mu2>
          <slip1>0.0</slip1>
          <slip2>0.0</slip2>
        </ode>
      </friction>
      <contact>
        <ode>
          <kp>1000000.0</kp>
          <kd>1.0</kd>
          <min_depth>0.001</min_depth>
        </ode>
      </contact>
    </surface>
  </gazebo>

  <!-- Caster wheels: zero friction, high damping -->
  <gazebo reference="caster_wheel">
    <material>Gazebo/Gray</material>
    <surface>
      <friction>
        <ode>
          <mu>0.0</mu>
          <mu2>0.0</mu2>
        </ode>
      </friction>
      <contact>
        <ode>
          <kp>1000000.0</kp>
          <kd>100.0</kd>
          <min_depth>0.001</min_depth>
        </ode>
      </contact>
    </surface>
  </gazebo>

  <gazebo reference="rear_caster_wheel">
    <material>Gazebo/Gray</material>
    <surface>
      <friction>
        <ode>
          <mu>0.0</mu>
          <mu2>0.0</mu2>
        </ode>
      </friction>
      <contact>
        <ode>
          <kp>1000000.0</kp>
          <kd>100.0</kd>
          <min_depth>0.001</min_depth>
        </ode>
      </contact>
    </surface>
  </gazebo>

  <gazebo reference="chassis">
    <material>Gazebo/Orange</material>
  </gazebo>

  <gazebo reference="lidar_link">
    <material>Gazebo/Red</material>
  </gazebo>

</robot>
